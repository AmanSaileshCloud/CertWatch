# ─────────────────────────────────────────────────────────────────────────────
# CERTWatch production environment — single EC2 t2.micro.
# Copy to /etc/certwatch/certwatch.env and fill in the CHANGE_ME values.
# Loaded by both the API service and the checker timer (systemd EnvironmentFile).
# ─────────────────────────────────────────────────────────────────────────────

# ── Storage: single-file SQLite on the box ──────────────────────────────────
BACKEND=aws
STORAGE=sqlite
SQLITE_PATH=/opt/certwatch/data/certwatch.db

# ── Alerts: AWS SNS + SES (per manager) ──────────────────────────────────────
# Credentials come from the EC2 IAM instance role — do NOT put AWS keys here.
# Leave AWS_ENDPOINT_URL empty so boto3 resolves real AWS endpoints.
NOTIFIER=sns_ses
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:CHANGE_ME_ACCOUNT_ID:ssl-alerts
ALERT_EMAIL=alerts@yourcompany.com

# ── Checker behaviour ─────────────────────────────────────────────────────────
THRESHOLD_DAYS=30,14,7,1
TLS_TIMEOUT_SECONDS=10

# ── Auth: username/password JWT (self-contained) ──────────────────────────────
AUTH_ENABLED=true
# Long random secret (openssl rand -hex 32). The API refuses to start with the
# built-in default when AUTH_ENABLED=true.
AUTH_SECRET=CHANGE_ME_LONG_RANDOM_32_CHARS_MINIMUM
AUTH_TOKEN_EXPIRE_MINUTES=720
AUTH_USERS_FILE=/opt/certwatch/data/auth_users.json
# Password for the auto-seeded 'admin' user on first run (change after logging in).
AUTH_BOOTSTRAP_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Daily digest email (SMTP; optional) ─────────────────────────────────────
# Only needed for the admin "Send digest" feature. Any SMTP provider works.
MAILER=console
# MAILER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=CERTWatch <you@yourdomain.com>

# ── CORS: empty — the frontend is same-origin behind Nginx ───────────────────
CORS_ORIGINS=
